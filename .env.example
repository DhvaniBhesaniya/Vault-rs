# ─── Server ───
HOST=0.0.0.0
PORT=8080

# ─── MongoDB ───
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=rustvault

# ─── JWT ───
# IMPORTANT: Change this in production!
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_generate_a_long_random_string
JWT_ACCESS_TOKEN_EXPIRY_SECS=900
JWT_REFRESH_TOKEN_EXPIRY_SECS=604800

# ─── Argon2id Parameters ───
ARGON2_MEMORY_KB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# ─── Rate Limiting ───
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_SECS=900
RATE_LIMIT_WRITE_MAX=60
RATE_LIMIT_WRITE_WINDOW_SECS=60
RATE_LIMIT_READ_MAX=120
RATE_LIMIT_READ_WINDOW_SECS=60

# ─── Account Lockout ───
MAX_FAILED_LOGIN_ATTEMPTS=10
LOCKOUT_DURATION_SECS=3600

# ─── Logging ───
RUST_LOG=vault_rs=debug,tower_http=debug
